<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/Cream"
    tools:context=".ShoppingList.AddActivity"
    android:padding="24dp">

    <EditText
        android:id="@+id/tvProductInput"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="108dp"
        android:background="@drawable/edit_text_background"
        android:hint="Product"
        android:inputType="textCapSentences"
        android:padding="16dp"
        android:textColor="@color/White"
        android:textColorHint="@color/White"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/tvQuantityInput"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:hint="Quantity"
        android:inputType="numberDecimal"
        android:background="@drawable/edit_text_background"
        android:padding="16dp"
        android:textSize="18sp"
        android:textColor="@color/White"
        android:textColorHint="@color/White"
        app:layout_constraintTop_toBottomOf="@id/tvProductInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/SpinnerUnit"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="12dp" />

    <Spinner
        android:id="@+id/SpinnerUnit"
        android:layout_width="120dp"
        android:layout_height="72dp"
        android:background="@drawable/spinner_background"
        android:padding="16dp"
        android:spinnerMode="dropdown"
        app:layout_constraintTop_toTopOf="@id/tvQuantityInput"
        app:layout_constraintBottom_toBottomOf="@id/tvQuantityInput"
        app:layout_constraintStart_toEndOf="@id/tvQuantityInput"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btAddProduct"
        android:layout_width="160dp"
        android:layout_height="72dp"
        android:layout_marginTop="184dp"
        android:background="@drawable/button_background_green"
        android:text="ADD"
        android:textColor="@color/White"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvQuantityInput" />
</androidx.constraintlayout.widget.ConstraintLayout>
